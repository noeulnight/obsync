# Copy this file to .env and fill every empty value.
POSTGRES_PASSWORD=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Browser-visible endpoints. Use HTTPS URLs in production.
WEB_URL=http://localhost:8080
REGISTRATION_ENABLED=true

# Optional OpenID Connect single sign-on
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid email profile
S3_PUBLIC_ENDPOINT=http://localhost:9000
WEB_PORT=8080
